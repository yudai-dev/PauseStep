{
  "manifest_version": 3,
  "name": "PauseStep",
  "version": "0.4.0",
  "description": "SNSを開く前にひと呼吸を促し、称賛のみの条件Aと学習導線付きの条件Bを切り替えて比較できます。",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://x.com/*",
    "*://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "PauseStepの設定と結果を開く"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://x.com/*",
        "*://www.instagram.com/*"
      ],
      "css": [
        "content/intervention.css"
      ],
      "js": [
        "content/intervention.js"
      ],
      "run_at": "document_start"
    }
  ]
}
