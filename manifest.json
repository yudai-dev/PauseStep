{
  "manifest_version": 3,
  "name": "学習着手支援",
  "version": "0.3.3",
  "description": "SNSを開く前に静かな10秒介入を表示し、やめた直後の成功画面で学習着手を任意に提案します。",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://x.com/*",
    "*://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "学習着手支援の設定を開く"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://x.com/*",
        "*://www.instagram.com/*"
      ],
      "css": [
        "content/intervention.css"
      ],
      "js": [
        "content/intervention.js"
      ],
      "run_at": "document_start"
    }
  ]
}
